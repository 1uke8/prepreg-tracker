{
  "name": "Transfer",
  "type": "object",
  "properties": {
    "transfer_number": {
      "type": "string",
      "description": "Transfer identifier"
    },
    "group_id": {
      "type": "string",
      "description": "Group ID for multi-item transfers"
    },
    "item_type": {
      "type": "string",
      "enum": [
        "stock",
        "kit"
      ],
      "default": "stock",
      "description": "Type of item being transferred"
    },
    "stock_id": {
      "type": "string",
      "description": "Stock item being transferred (if item_type is stock)"
    },
    "kit_id": {
      "type": "string",
      "description": "Kit being transferred (if item_type is kit)"
    },
    "material_name": {
      "type": "string"
    },
    "batch_number": {
      "type": "string"
    },
    "from_location": {
      "type": "string"
    },
    "to_location": {
      "type": "string"
    },
    "quantity": {
      "type": "number"
    },
    "unit": {
      "type": "string"
    },
    "transfer_date": {
      "type": "string",
      "format": "date-time"
    },
    "out_time_start": {
      "type": "string",
      "format": "date-time",
      "description": "When out-time tracking started"
    },
    "out_time_end": {
      "type": "string",
      "format": "date-time",
      "description": "When returned to freezer"
    },
    "reason": {
      "type": "string",
      "description": "Transfer reason"
    },
    "transferred_by": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "Pending",
        "In Transit",
        "Completed",
        "Cancelled"
      ],
      "default": "Completed"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "from_location",
    "to_location"
  ]
}